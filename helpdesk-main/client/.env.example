# ─── Error Tracking (Sentry) — Optional ────────────────────────────────────
VITE_SENTRY_DSN=""
VITE_SENTRY_ENVIRONMENT="production"

# ─── Sentry Source Maps (CI/Build-time only) ───────────────────────────────
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

