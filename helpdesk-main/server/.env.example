# ─── Database ───────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (includes pg-boss job queue)
DATABASE_URL="postgresql://user:password@host/database?sslmode=verify-full"

# ─── Authentication (Better Auth) ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Must match your production URL (used for cookie domain + callback URLs)
BETTER_AUTH_URL="https://your-app.onrender.com"

# ─── CORS / Trusted Origins ────────────────────────────────────────────────
# Comma-separated list of allowed origins (must include your production URL)
TRUSTED_ORIGINS="https://your-app.onrender.com"

# ─── Webhook Security ──────────────────────────────────────────────────────
# Shared secret for inbound email webhook (CloudMailin sends via X-Webhook-Secret header or ?secret= query param)
WEBHOOK_SECRET=""

# ─── AI (Groq) ─────────────────────────────────────────────────────────────
GROQ_API_KEY=""
# Optional: defaults to llama-3.1-8b-instant
GROQ_MODEL="llama-3.1-8b-instant"

# ─── Outbound Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=""
# Verified sender address (e.g. support@yourdomain.com)
RESEND_FROM_EMAIL=""

# ─── Outbound Email (SMTP / Alternative to Resend - No Domain Required) ────
# If set, outbound email will use SMTP instead of Resend (e.g. for Gmail)
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-gmail-app-password" (use an App Password, not your normal password)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_FROM_EMAIL="your-email@gmail.com"

# ─── File Storage (Cloudinary) ─────────────────────────────────────────────
# Option A: single URL (preferred)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# Option B: individual credentials (used if CLOUDINARY_URL is not set)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ─── Error Tracking (Sentry) — Optional ────────────────────────────────────
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"

# ─── Database Seed (first deploy only) ─────────────────────────────────────
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# ─── Connection Pool Tuning — Optional ─────────────────────────────────────
# PRISMA_POOL_MAX=3
# PG_BOSS_POOL_MAX=2
# PG_BOSS_CONNECTION_TIMEOUT_MS=30000